# Streaming Platform — variaveis de ambiente
# Copie para .env e ajuste conforme necessario

# Banco PostgreSQL
POSTGRES_DB=streaming
POSTGRES_USER=streaming
POSTGRES_PASSWORD=streaming

# ClickHouse
CLICKHOUSE_DB=logs
CLICKHOUSE_USER=streaming
CLICKHOUSE_PASSWORD=streaming

# MinIO (S3-compatible)
MINIO_ROOT_USER=streaming
MINIO_ROOT_PASSWORD=streaming123

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Kafka
KAFKA_BROKER=kafka:9092

# OTel Collector endpoint (usado pelos servicos)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# k6 (para rodar localmente)
K6_BASE_URL=http://localhost
